@model TodoApp.Models.TodoItem

@{
    ViewData["Title"] = "Editează Task-ul";
}

<h2 class="my-4">Editează Task-ul</h2>

<div class="card shadow-sm p-4 w-50">
    <form asp-action="Edit" method="post">
        @Html.AntiForgeryToken()
        <input type="hidden" asp-for="Id" />
        <input type="hidden" asp-for="CreatedAt" />

        <div class="mb-3">
            <label asp-for="Title" class="form-label">Titlu</label>
            <input asp-for="Title" class="form-control" required />
            <span asp-validation-for="Title" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="DueDate" class="form-label">Termen limită (opțional)</label>
            <input asp-for="DueDate" type="date" class="form-control" />
            <span asp-validation-for="DueDate" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="TaskPriority" class="form-label">Prioritate</label>
            <select asp-for="TaskPriority" class="form-select" asp-items="Html.GetEnumSelectList<TodoApp.Models.Priority>()"></select>
            <span asp-validation-for="TaskPriority" class="text-danger"></span>
        </div>

        <div class="form-check mb-3">
            <input asp-for="IsCompleted" class="form-check-input" type="checkbox" />
            <label asp-for="IsCompleted" class="form-check-label">Task finalizat?</label>
        </div>

        <button type="submit" class="btn btn-primary">Salvează Modificările</button>
        <a asp-action="Index" class="btn btn-secondary ms-2">Înapoi la Listă</a>
    </form>
</div>
